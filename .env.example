# =============================================================================
# LOCAL DOCKER (copy to .env — optional, docker-compose sets these automatically)
# =============================================================================
POSTGRES_USER=inspection_user
POSTGRES_PASSWORD=inspection_pass
POSTGRES_DB=machine_inspection
SECRET_KEY=change-this-secret-key-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# =============================================================================
# CLOUD API (Render / Railway) — REQUIRED, do not use localhost
# =============================================================================
# Get free PostgreSQL from https://neon.tech then paste connection string:
#
# DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# Your Vercel frontend URL (for CORS):
# CORS_ORIGINS=https://your-app.vercel.app

# =============================================================================
# CLOUD FRONTEND (Vercel) — set in Vercel dashboard, NOT here
# =============================================================================
# VITE_API_URL=https://your-api.onrender.com/api
