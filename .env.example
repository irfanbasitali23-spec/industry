# =============================================================================
# DOCKER COMPOSE — copy to .env (optional)
#   copy .env.example .env
#   docker compose up -d --build
# =============================================================================
# Uses LOCAL PostgreSQL container — do NOT add Neon POSTGRES_URL here.

POSTGRES_USER=inspection_user
POSTGRES_PASSWORD=inspection_pass
POSTGRES_DB=machine_inspection
SECRET_KEY=change-this-to-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# VERCEL + NEON (cloud only — do not use with Docker)
# =============================================================================
# POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@ep-xxxx.neon.tech/neondb?sslmode=require
# PGUSER=neondb_owner
# PGPASSWORD=your_password
# PGHOST_UNPOOLED=ep-xxxx.neon.tech
# PGDATABASE=neondb
